# ============================================================
# 한국투자증권 KIS API 환경변수
# 이 파일을 복사하여 .env 로 저장하고 실제 값을 입력하세요
# .env 파일은 절대 git에 커밋하지 마세요!
#
# [계좌 발급 순서]
# 1. https://apiportal.koreainvestment.com 접속
# 2. 로그인 → 상단 "모의투자" 탭
# 3. "국내주식 모의투자" 앱 생성 → 앱키/시크릿 발급
# 4. "해외주식 모의투자" 앱 생성 → 앱키/시크릿 발급 (별도 앱)
# 5. 각 계좌번호 확인 (국내/해외 계좌번호가 다릅니다)
# ============================================================

# ── 국내주식 모의투자 ─────────────────────────────────────────
KIS_DOMESTIC_APP_KEY=your_domestic_app_key
KIS_DOMESTIC_APP_SECRET=your_domestic_app_secret
KIS_DOMESTIC_CANO=12345678          # 국내 모의투자 계좌번호 앞 8자리
KIS_DOMESTIC_ACNT_PRDT_CD=01       # 모의투자 계좌상품코드 (항상 01)

# ── 해외주식 모의투자 ─────────────────────────────────────────
KIS_OVERSEAS_APP_KEY=your_overseas_app_key
KIS_OVERSEAS_APP_SECRET=your_overseas_app_secret
KIS_OVERSEAS_CANO=12345678          # 해외 모의투자 계좌번호 앞 8자리
KIS_OVERSEAS_ACNT_PRDT_CD=01       # 모의투자 계좌상품코드 (항상 01)

# ── 모드 ─────────────────────────────────────────────────────
KIS_MODE=sandbox                    # sandbox=모의투자 / production=실투자

# ── 하위 호환 (= 국내 계좌와 동일하게 설정) ──────────────────
KIS_APP_KEY=your_domestic_app_key
KIS_APP_SECRET=your_domestic_app_secret
KIS_CANO=12345678
KIS_ACNT_PRDT_CD=01
